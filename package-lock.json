interface EmojiStickerPickerProps {
  onEmojiSelect: (emoji: string) => void;
  onStickerSelect: (sticker: string) => void;
  onClose: () => void;
}

export default function EmojiStickerPicker({ onEmojiSelect, onStickerSelect, onClose }: EmojiStickerPickerProps) {
  const { currentUser, addSticker, removeSticker } = useStore();
  const [tab, setTab] = useState<'emoji' | 'sticker'>('emoji');
  const [activeCategory, setActiveCategory] = useState(0);
  const [search, setSearch] = useState('');
  const fileRef = useRef<HTMLInputElement>(null);

  const stickers = currentUser?.stickers || [];

  const handleAddSticker = (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0];
    if (!file) return;
    if (file.size > 512 * 1024) {
      alert('Стикер должен быть не более 512КБ');
      return;
    }
    const reader = new FileReader();
    reader.onload = () => {
      addSticker(reader.result as string);
    };
    reader.readAsDataURL(file);
    e.target.value = '';
  };

  return (
    <div className="absolute bottom-full left-0 mb-2 w-[min(340px,calc(100vw-16px))] max-w-[calc(100vw-16px)] bg-gray-800/95 backdrop-blur-xl border border-white/15 rounded-2xl shadow-2xl overflow-hidden animate-fadeIn z-50">
      {/* Tab switcher */}
      <div className="flex items-center border-b border-white/10">
        <button
          onClick={() => setTab('emoji')}
          className={`flex-1 flex items-center justify-center gap-2 py-3 text-sm font-medium transition-all ${
            tab === 'emoji'
              ? 'text-yellow-400 border-b-2 border-yellow-400 bg-yellow-400/5'
              : 'text-white/40 hover:text-white/60'
          }`}
        >
          <Smile className="w-4 h-4" />
          Эмодзи
        </button>
        <button
          onClick={() => setTab('sticker')}
          className={`flex-1 flex items-center justify-center gap-2 py-3 text-sm font-medium transition-all ${
            tab === 'sticker'
              ? 'text-purple-400 border-b-2 border-purple-400 bg-purple-400/5'
              : 'text-white/40 hover:text-white/60'
          }`}
        >
          <ImageIcon className="w-4 h-4" />
          Стикеры
          {stickers.length > 0 && (
            <span className="text-[10px] bg-white/10 px-1.5 rounded-full">{stickers.length}</span>
          )}
        </button>
        <button onClick={onClose} className="p-2.5 text-white/30 hover:text-white transition mx-1">
          <X className="w-4 h-4" />
        </button>
      </div>

      {/* EMOJI TAB */}
      {tab === 'emoji' && (
        <>
          {/* Search */}
          <div className="flex items-center gap-2 px-3 py-2 border-b border-white/5">
            <Search className="w-4 h-4 text-white/30 flex-shrink-0" />
            <input
              type="text"
              value={search}
              onChange={e => setSearch(e.target.value)}
              placeholder="Поиск эмодзи..."
              className="flex-1 bg-transparent text-white text-sm placeholder-white/30 outline-none"
              autoFocus
            />
          </div>

          {/* Category tabs */}
          <div className="flex gap-0.5 px-2 py-1.5 border-b border-white/5 overflow-x-auto scrollbar-hide">
            {emojiCategories.map((cat, i) => (
              <button
                key={i}
                onClick={() => setActiveCategory(i)}
                className={`flex-shrink-0 w-8 h-8 flex items-center justify-center rounded-lg text-base transition ${
                  activeCategory === i ? 'bg-white/10 scale-110' : 'hover:bg-white/5 opacity-60 hover:opacity-100'
                }`}
                title={cat.name}
              >
                {cat.icon}
              </button>
            ))}
          </div>

          {/* Emoji grid */}
          <div className="h-56 overflow-y-auto p-2">
            {(search
              ? emojiCategories
              : [emojiCategories[activeCategory]]
            ).map((cat, ci) => (
              <div key={ci}>
                {search && <div className="text-white/30 text-xs px-1 mb-1 mt-1">{cat.name}</div>}
                <div className="grid grid-cols-8 gap-0.5">
                  {cat.emojis.map((emoji, i) => (
                    <button
                      key={i}
                      onClick={() => onEmojiSelect(emoji)}
                      className="w-9 h-9 flex items-center justify-center rounded-lg hover:bg-white/10 active:scale-90 text-xl transition-all"
                    >
                      {emoji}
                    </button>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </>
      )}

      {/* STICKER TAB */}
      {tab === 'sticker' && (
        <>
          <input
            ref={fileRef}
            type="file"
            accept="image/*"
            onChange={handleAddSticker}
            className="hidden"
          />
            <div className="h-[280px] sm:h-[300px] overflow-y-auto p-3">
            {stickers.length === 0 ? (
              <div className="flex flex-col items-center justify-center h-full text-center">
                <div className="w-20 h-20 rounded-full bg-white/5 flex items-center justify-center mb-3">
                  <ImageIcon className="w-10 h-10 text-white/15" />
                </div>
                <p className="text-white/30 text-sm mb-1">Нет стикеров</p>
                <p className="text-white/20 text-xs mb-4">Загрузите свои изображения</p>
                <button
                  onClick={() => fileRef.current?.click()}
                  className="px-5 py-2.5 bg-purple-500/20 text-purple-400 text-sm rounded-xl hover:bg-purple-500/30 transition flex items-center gap-2 font-medium"
                >
                  <Plus className="w-4 h-4" /> Добавить стикер
                </button>
              </div>
            ) : (
              <>
                <div className="grid grid-cols-3 gap-2 mb-3">
                  {stickers.map((sticker, i) => (
                    <div key={i} className="relative group">
                      <button
                        onClick={() => onStickerSelect(sticker)}
                        className="w-full aspect-square rounded-xl overflow-hidden bg-white/5 hover:bg-white/10 transition border border-white/10 hover:border-purple-400/30 hover:shadow-lg hover:shadow-purple-500/10"
                      >
                        <img src={sticker} alt="sticker" className="w-full h-full object-contain p-1.5" />
                      </button>
                      <button
                        onClick={(e) => {
                          e.stopPropagation();
                          removeSticker(i);
                        }}
                        className="absolute -top-1.5 -right-1.5 w-5 h-5 bg-red-500 rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition shadow-lg"
                      >
                        <Trash2 className="w-3 h-3 text-white" />
                      </button>
                    </div>
                  ))}
                </div>
                <button
                  onClick={() => fileRef.current?.click()}
                  className="w-full py-2.5 border-2 border-dashed border-white/10 hover:border-purple-400/30 rounded-xl text-white/30 hover:text-purple-400 text-sm transition flex items-center justify-center gap-2"
                >
                  <Plus className="w-4 h-4" /> Добавить ещё
                </button>
              </>
            )}
          </div>
        </>
      )}
    </div>
  );
}
